{
  "name": "chatroom-cli",
  "version": "1.58.6",
  "description": "CLI for multi-agent chatroom collaboration",
  "type": "module",
  "bin": {
    "chatroom": "./dist/node-launch.js"
  },
  "scripts": {
    "build": "bun run typecheck && bun run build.config.ts",
    "typecheck": "tsc -b --force",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "chatroom": "bun run src/index.ts",
    "prepublishOnly": "bun run scripts/guard-workspace-publish.ts",
    "publish:prepare": "bun run scripts/prepare-npm-publish.ts",
    "publish:verify": "bun run scripts/verify-publish-artifacts.ts"
  },
  "dependencies": {
    "@connectrpc/connect-node": "^1.6.1",
    "@cursor/sdk": "1.0.19",
    "@earendil-works/pi-coding-agent": "0.74.2",
    "@llamaindex/liteparse": "^1.4.2",
    "@opencode-ai/sdk": "^1.14.22",
    "commander": "^14.0.0",
    "convex": "^1.31.0",
    "convex-helpers": "^0.1.108",
    "effect": "^3.0.0",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "@workspace/backend": "workspace:*",
    "typescript": "^5.0.0",
    "vite": "^6.3.5",
    "vitest": "^4.0.6"
  },
  "keywords": [
    "cli",
    "chatroom",
    "multi-agent",
    "convex"
  ],
  "author": "",
  "license": "Elastic-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/conradkoh/chatroom"
  },
  "files": [
    "dist/index.js",
    "dist/index.js.map",
    "dist/node-launch.js",
    "dist/node-launch.js.map",
    "package.json",
    "README.md"
  ]
}
