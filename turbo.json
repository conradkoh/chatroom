{
  "$schema": "https://turbo.build/schema.json",
  "cacheMaxAge": "7d",
  "cacheMaxSize": "10GB",
  "globalDependencies": ["pnpm-lock.yaml"],
  "tasks": {
    "build": {
      "dependsOn": ["^typecheck"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "cache": true
    },
    "test": {
      "dependsOn": ["^typecheck", "typecheck"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "e2e": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "cache": false
    },
    "@workspace/backend#typecheck": {
      "outputs": ["dist/**"]
    },
    "@workspace/webapp#typecheck": {
      "inputs": ["$TURBO_DEFAULT$", ".env*", "$TURBO_ROOT$/services/backend/src/**"]
    },
    "@workspace/webapp#build": {
      "dependsOn": ["^typecheck", "typecheck"],
      "outputs": [".next/**", "!.next/cache/**"]
    }
  }
}
