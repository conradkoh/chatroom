    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@sentry/nextjs": "^10.57.0",
    "@tanstack/react-virtual": "^3.13.26",
    "@types/luxon": "^3.6.2",
    "@types/mdx": "^2.0.13",
    "@workspace/backend": "workspace:*",
