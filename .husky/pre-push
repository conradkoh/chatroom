#!/usr/bin/env sh

echo "Running pre-push checks..."

echo "→ pnpm typecheck"
pnpm typecheck
if [ $? -ne 0 ]; then
    echo "Typecheck failed. Please fix the errors before pushing."
    exit 1
fi

echo "→ pnpm test"
pnpm test
if [ $? -ne 0 ]; then
    echo "Tests failed. Please fix the errors before pushing."
    exit 1
fi

echo "→ pnpm turbo run build"
pnpm turbo run build
if [ $? -ne 0 ]; then
    echo "Build failed. Please fix the errors before pushing."
    exit 1
fi

echo "All pre-push checks passed. Proceeding with push."
