{
  "name": "@workspace/backend",
  "version": "1.69.2",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "CONVEX_NON_INTERACTIVE=true DOCUMENT_RETENTION_DELAY=1 INDEX_RETENTION_DELAY=1 RETENTION_DELETE_FREQUENCY=10 convex dev",
    "deploy": "convex deploy",
    "migrate": "bun ../../scripts/migrate.ts",
    "migrate:saved-command-scope": "convex run migrations:run '{\"fn\":\"migrations:backfillSavedCommandScope\"}'",
    "migrate:duo-builder-want-resume": "convex run migrations:run '{\"fn\":\"migrations:setDuoBuilderWantResumeFalse\"}'",
    "typecheck": "tsc --build",
    "test": "bash ../../scripts/kill-stale-vitest.sh \"$PWD\" && vitest run",
    "test:watch": "bash ../../scripts/kill-stale-vitest.sh \"$PWD\" && vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@convex-dev/aggregate": "^0.2.2",
    "@convex-dev/migrations": "^0.3.5",
    "convex": "^1.42.2",
    "convex-helpers": "^0.1.120",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "convex-test": "^0.0.54",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.10"
  }
}
